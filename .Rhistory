library(lubridate)
library(dplyr)
install.packages("lubridate")
library(lubridate)
# Convert 'date' to Date format if it's not already
food_prices_o$date <- as.Date(food_prices_o$date, format = "%Y-%m-%d")
# Extract only the year from the date (remove month and day)
food_prices_o$year <- year(food_prices_o$date)
# Sort the data by admin1 (town) and year (to ensure correct order)
food_prices_o <- food_prices_o %>%
arrange(admin1, year)
# Calculate the yearly growth rate for each town
food_prices_o <- food_prices_o %>%
group_by(admin1, year) %>%
mutate(
# Calculate the growth rate for each town, comparing the price for each year
growth_rate = (usdprice - lag(usdprice)) / lag(usdprice) * 100
) %>%
ungroup()
# View the first few rows of the updated data
head(food_prices_o)
library(dplyr)
install.packages("lubridate")
library(lubridate)
food_prices_o$date <- as.Date(food_prices_o$date, format = "%Y-%m-%d")
food_prices_o$year <- format(food_prices_o$date, "%Y")
food_prices_o <- food_prices_o %>%
arrange(market, year)
food_prices_o <- food_prices_o %>%
group_by(market, year) %>%
mutate(
growth_rate = (usdprice - lag(usdprice)) / lag(usdprice) * 100
) %>%
ungroup()
growth_rate_table <- food_prices_o %>%
select(market, year, growth_rate)
head(growth_rate_table)
install.packages("lubridate")
